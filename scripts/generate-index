#!/usr/bin/env python3
"""Generate or verify topic index links.

Usage:
  scripts/generate-index docs/components
  scripts/generate-index --check docs/components docs/requirements
  scripts/generate-index --check
  scripts/generate-index --write docs/start-here

By default, the command prints a Markdown bullet list for each requested section.
With --check, it verifies that each section index links to every sibling
Markdown page. With --write, it updates only content between these markers:

  <!-- generated-index:start -->
  <!-- generated-index:end -->

The script intentionally avoids rewriting custom indexes without markers. Many
cookbook indexes include decision guidance, tables, and examples that should not
be replaced by a blind filesystem listing.
"""

from __future__ import annotations

import argparse
import re
import sys
from dataclasses import dataclass
from pathlib import Path
from urllib.parse import unquote, urlparse


START_MARKER = "<!-- generated-index:start -->"
END_MARKER = "<!-- generated-index:end -->"
HEADING_RE = re.compile(r"^#\s+(.+?)\s*$", re.MULTILINE)
LINK_RE = re.compile(r"!?\[[^\]\n]+\]\(([^)\s]+)(?:\s+\"[^\"]*\")?\)")
SCHEME_RE = re.compile(r"^[a-zA-Z][a-zA-Z0-9+.-]*:")


@dataclass(frozen=True)
class Page:
    path: Path
    link: str
    title: str


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Generate or verify Markdown links in docs topic indexes.",
        epilog=(
            "If no section is provided, all first-level docs sections with an "
            "index.md file are checked or generated."
        ),
    )
    parser.add_argument(
        "sections",
        nargs="*",
        type=Path,
        help="Section directories containing index.md, for example docs/components.",
    )
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument(
        "--check",
        action="store_true",
        help="Verify each index links to its sibling Markdown pages.",
    )
    mode.add_argument(
        "--write",
        action="store_true",
        help="Update the generated marker block in each index.md.",
    )
    return parser.parse_args()


def discover_sections(explicit_sections: list[Path]) -> list[Path]:
    if explicit_sections:
        return [section for section in explicit_sections]

    docs_dir = Path("docs")
    if not docs_dir.is_dir():
        raise SystemExit("docs directory not found")

    return sorted(
        section
        for section in docs_dir.iterdir()
        if section.is_dir() and (section / "index.md").is_file()
    )


def page_title(path: Path) -> str:
    text = path.read_text(encoding="utf-8")
    match = HEADING_RE.search(text)
    if match:
        return match.group(1).strip(" `")
    return path.stem.replace("-", " ").title()


def section_pages(section: Path) -> list[Page]:
    pages: list[Page] = []
    for path in sorted(section.glob("*.md")):
        if path.name == "index.md":
            continue
        pages.append(Page(path=path, link=path.name, title=page_title(path)))
    return pages


def generated_block(section: Path) -> str:
    pages = section_pages(section)
    if not pages:
        return "_No sibling Markdown pages found._"
    return "\n".join(f"- [{page.title}]({page.link})" for page in pages)


def linked_targets(index_path: Path) -> set[str]:
    text = index_path.read_text(encoding="utf-8")
    targets: set[str] = set()
    for match in LINK_RE.finditer(text):
        raw_target = match.group(1)
        target = raw_target.split("#", 1)[0]
        if not target or SCHEME_RE.match(target):
            continue

        parsed = urlparse(target)
        if parsed.scheme or parsed.netloc:
            continue

        normalized = unquote(parsed.path or target)
        targets.add(normalized)
    return targets


def verify_section(section: Path) -> list[str]:
    index_path = section / "index.md"
    if not index_path.is_file():
        return [f"{section}: missing index.md"]

    targets = linked_targets(index_path)
    problems: list[str] = []
    for page in section_pages(section):
        accepted = {page.link, f"./{page.link}", str(page.path)}
        if not accepted.intersection(targets):
            problems.append(f"{index_path}: missing link to {page.link}")
    return problems


def write_section(section: Path) -> list[str]:
    index_path = section / "index.md"
    if not index_path.is_file():
        return [f"{section}: missing index.md"]

    text = index_path.read_text(encoding="utf-8")
    start = text.find(START_MARKER)
    end = text.find(END_MARKER)
    if start == -1 or end == -1 or end < start:
        return [
            f"{index_path}: generated markers not found; refusing to rewrite custom content"
        ]

    before = text[: start + len(START_MARKER)]
    after = text[end:]
    new_text = f"{before}\n{generated_block(section)}\n{after}"
    if new_text != text:
        index_path.write_text(new_text, encoding="utf-8")
        return [f"{index_path}: updated"]
    return [f"{index_path}: already up to date"]


def validate_section_paths(sections: list[Path]) -> list[str]:
    problems: list[str] = []
    for section in sections:
        if not section.is_dir():
            problems.append(f"{section}: section directory not found")
        elif not (section / "index.md").is_file():
            problems.append(f"{section}: index.md not found")
    return problems


def main() -> int:
    args = parse_args()
    sections = discover_sections(args.sections)
    path_problems = validate_section_paths(sections)
    if path_problems:
        print("\n".join(path_problems), file=sys.stderr)
        return 1

    if args.check:
        problems: list[str] = []
        for section in sections:
            problems.extend(verify_section(section))
        if problems:
            print("\n".join(problems))
            print(f"{len(problems)} problem(s)")
            return 1
        print(f"verified {len(sections)} section index(es)")
        return 0

    if args.write:
        results: list[str] = []
        problems: list[str] = []
        for section in sections:
            messages = write_section(section)
            for message in messages:
                if "refusing" in message or "missing" in message:
                    problems.append(message)
                else:
                    results.append(message)
        if results:
            print("\n".join(results))
        if problems:
            print("\n".join(problems), file=sys.stderr)
            return 1
        return 0

    for index, section in enumerate(sections):
        if index:
            print()
        print(f"## {section}")
        print()
        print(generated_block(section))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
